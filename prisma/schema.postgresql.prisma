// Hill-Haat - Farm-to-Highway Marketplace for Northeast India
// PostgreSQL Schema for Vercel + Neon Production Deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// User model - Farmers, Buyers, and Logistics Providers
model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(BUYER)
  district      String?
  state         String?
  address       String?
  pincode       String?
  
  businessName  String?
  description   String?
  
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  
  aadhaarVerified Boolean @default(false)
  panVerified     Boolean @default(false)
  bankAccountVerified Boolean @default(false)
  verificationDocuments String?
  verifiedBy     String?
  
  totalSales    Int       @default(0)
  totalPurchases Int      @default(0)
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  
  notificationsEnabled Boolean @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings        Listing[]
  ordersAsBuyer   Order[]   @relation("BuyerOrders")
  ordersAsSeller  Order[]  @relation("SellerOrders")
  deliveries      Delivery[]
  reviews         Review[]
  notifications   Notification[]
  cartItems       CartItem[]
  logisticsPartner LogisticsPartner?
  rider           Rider?
  verifications   Verification[]

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

enum UserRole {
  FARMER
  BUYER
  LOGISTICS
  ADMIN
}

model Listing {
  id              String        @id @default(cuid())
  title           String
  description     String
  category        Category
  subcategory     String?
  
  price           Float
  unit            String        @default("kg")
  minOrder        Float         @default(1)
  maxQuantity     Float?
  
  quality         QualityGrade  @default(A)
  isOrganic       Boolean       @default(false)
  organicCertHash String?
  isVerified      Boolean       @default(false)
  
  district        String
  state           String
  coordinates     String?
  latitude        Float?
  longitude       Float?
  elevation       Int?
  nearestHighway  String?
  nearestMarket   String?
  
  status          ListingStatus @default(ACTIVE)
  availableFrom   DateTime?
  availableUntil  DateTime?
  harvestDate     DateTime?
  
  images          String?
  
  viewCount       Int           @default(0)
  orderCount      Int           @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  expiresAt       DateTime?
  
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id])
  orders          Order[]
  reviews         Review[]
  cartItems       CartItem[]

  @@index([category])
  @@index([status])
  @@index([district])
  @@index([createdAt])
  @@index([state])
}

enum Category {
  VEGETABLES
  FRUITS
  SPICES
  GRAINS
  DAIRY
  HERBS
  BAMBOO_PRODUCTS
  HANDICRAFTS
  TEA
  HONEY
  OTHER
}

enum QualityGrade {
  A_PLUS
  A
  B
  C
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
  SUSPENDED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid())
  
  buyerId         String
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId        String
  seller          User        @relation("SellerOrders", fields: [sellerId], references: [id])
  
  listingId       String
  listing         Listing     @relation(fields: [listingId], references: [id])
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String?
  transactionId   String?
  
  deliveryAddress String
  deliveryDistrict String
  deliveryState   String
  deliveryPincode String?
  deliveryPhone   String
  
  terrainType     TerrainType?
  elevationGain   Int?
  deliveryRouteId String?
  riderId         String?
  estimatedDeliveryTime Int?
  deliveryDifficulty Int?
  
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  
  notes           String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  delivery        Delivery?
  tracking        TrackingEvent[]
  deliveryRoute   DeliveryRoute? @relation(fields: [deliveryRouteId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([deliveryState])
  @@index([deliveryDistrict])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Delivery {
  id              String          @id @default(cuid())
  orderId         String          @unique
  order           Order           @relation(fields: [orderId], references: [id])
  
  riderId         String
  rider           User            @relation(fields: [riderId], references: [id])
  
  pickupLocation  String
  dropLocation    String
  estimatedDistance Float?
  estimatedTime   Int?
  
  terrainType     TerrainType     @default(MIXED)
  difficultyLevel Int             @default(1)
  
  status          DeliveryStatus  @default(ASSIGNED)
  assignedAt      DateTime?
  pickedUpAt      DateTime?
  completedAt     DateTime?
  
  currentLocation String?
  lastLocationUpdate DateTime?
  
  baseFare        Float
  terrainBonus    Float           @default(0)
  totalEarnings   Float
  
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([riderId])
  @@index([status])
}

enum TerrainType {
  PLAIN
  HILLY
  MOUNTAINOUS
  VALLEY
  MIXED
  RIVERINE
}

enum DeliveryStatus {
  ASSIGNED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  NEAR_DESTINATION
  DELIVERED
  FAILED
  CANCELLED
}

enum VehicleType {
  BIKE
  AUTO
  SMALL_TRUCK
  LARGE_TRUCK
  PICKUP
  TRACTOR
}

model DeliveryRoute {
  id              String      @id @default(cuid())
  name            String
  
  pickupLocation  String
  pickupDistrict  String
  pickupState     String
  pickupLatitude  Float?
  pickupLongitude Float?
  
  dropLocation    String
  dropDistrict    String
  dropState       String
  dropLatitude    Float?
  dropLongitude   Float?
  
  terrainType     TerrainType @default(MIXED)
  distance        Float
  estimatedTime   Int
  baseCost        Float
  
  elevationGain   Int         @default(0)
  maxElevation    Int         @default(0)
  
  connectivityScore Int       @default(5)
  hazardZones     String?
  
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  orders          Order[]

  @@index([pickupState])
  @@index([dropState])
  @@index([isActive])
}

model LogisticsPartner {
  id                  String      @id @default(cuid())
  userId              String      @unique
  
  businessName        String
  description         String?
  phone               String?
  
  vehicleType         VehicleType @default(SMALL_TRUCK)
  vehicleNumber       String?
  
  serviceableDistricts String?
  serviceableStates   String?
  terrainExpertise    String?
  
  currentLocation     String?
  currentDistrict     String?
  currentState        String?
  currentLatitude     Float?
  currentLongitude    Float?
  
  isAvailable         Boolean     @default(true)
  
  baseRate            Float       @default(30)
  perKmRate           Float       @default(8)
  terrainMultiplier   Float       @default(1.0)
  
  rating              Float       @default(0)
  totalDeliveries     Int         @default(0)
  
  isVerified          Boolean     @default(false)
  documentsVerified   Boolean     @default(false)
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  riders              Rider[]

  @@index([isAvailable])
  @@index([currentState])
}

model Rider {
  id                    String      @id @default(cuid())
  userId                String      @unique
  logisticsPartnerId    String?
  
  name                  String
  phone                 String
  avatar                String?
  
  vehicleType           VehicleType @default(BIKE)
  vehicleNumber         String?
  
  currentLocation       String?
  currentDistrict       String?
  currentState          String?
  currentLatitude       Float?
  currentLongitude      Float?
  
  serviceableDistricts  String?
  terrainExpertise      String?
  
  isAvailable           Boolean     @default(true)
  
  rating                Float       @default(0)
  totalDeliveries       Int         @default(0)
  
  aadhaarVerified       Boolean     @default(false)
  drivingLicenseVerified Boolean    @default(false)
  isVerified            Boolean     @default(false)
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logisticsPartner      LogisticsPartner? @relation(fields: [logisticsPartnerId], references: [id], onDelete: SetNull)

  @@index([isAvailable])
  @@index([currentDistrict])
  @@index([currentState])
}

model TrackingEvent {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  
  status      String
  location    String?
  description String
  timestamp   DateTime    @default(now())

  @@index([orderId])
  @@index([timestamp])
}

model Review {
  id          String    @id @default(cuid())
  rating      Int
  comment     String?
  
  listingId   String
  listing     Listing   @relation(fields: [listingId], references: [id])
  
  reviewerId  String
  reviewer    User      @relation(fields: [reviewerId], references: [id])
  
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([listingId])
  @@index([reviewerId])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  
  type        NotificationType
  title       String
  message     String
  data        String?
  
  isRead      Boolean           @default(false)
  readAt      DateTime?
  
  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  NEW_MESSAGE
  PRICE_DROP
  LISTING_EXPIRING
  PAYMENT_RECEIVED
  DELIVERY_ASSIGNED
  REVIEW_RECEIVED
  VERIFICATION_STATUS
}

enum VerificationType {
  AADHAAR
  PAN
  BANK_ACCOUNT
  ORGANIC_CERT
  LAND_RECORDS
  FARMER_ID
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model Verification {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            VerificationType
  status          VerificationStatus @default(PENDING)
  
  documentUrl     String?
  documentNumber  String?
  documentName    String?
  documentExpiry  DateTime?
  
  remarks         String?
  rejectionReason String?
  adminNotes      String?
  
  reviewedBy      String?
  reviewedAt      DateTime?
  
  submittedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([submittedAt])
}

model Inquiry {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  status      String    @default("PENDING")
  repliedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
}

model AppConfig {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String
  description String?
  updatedAt   DateTime  @updatedAt
}

model CartItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity    Float
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
}
